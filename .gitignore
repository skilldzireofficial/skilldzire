# Dependency folders (Chala heavy untay, GitHub ki avasaram ledu)
node_modules/
jspm_packages/

# Environment Variables (Most Important - Nee Email passwords & DB links indulo untay)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs (Frontend build chesinappudu vachevi)
dist/
build/
out/

# Logs (Error logs and system logs)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Operating System Files (System generated files)
.DS_Store
Thumbs.db
desktop.ini

# IDE Settings (Nee VS Code or WebStorm settings)
.vscode/
.idea/
*.swp
*.swo

# Uploads & Certificates (Users upload chese files GitHub ki vellakudadu)
frontend/uploads/
backend/assets/*.pdf
!backend/assets/template.png